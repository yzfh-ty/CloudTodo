generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
  deleted
}

enum TodoStatus {
  pending
  completed
  archived
  deleted
}

enum TodoPriority {
  low
  medium
  high
}

enum PlatformType {
  web
  android
  windows
}

enum ReminderRepeatType {
  none
  daily
  weekly
  workday
  custom
}

enum ReminderStatus {
  pending
  triggered
  cancelled
  failed
}

enum ReminderChannel {
  android_local
  windows_local
  webhook
}

enum ReminderEventStatus {
  pending
  processing
  processed
  failed
}

enum NotificationEndpointType {
  webhook
}

enum NotificationDeliveryStatus {
  pending
  processing
  success
  failed
  dead_letter
}

enum PasswordResetMode {
  temporary_password
  reset_token
}

enum AdminOperationAction {
  disable_user
  enable_user
  reset_user_password
  update_user_profile
  change_admin_password
  logout_all_sessions
}

enum AdminOperationResult {
  success
  failed
}

model User {
  id                         String                   @id @default(uuid()) @db.Uuid
  email                      String                   @unique @db.VarChar(255)
  username                   String                   @unique @db.VarChar(64)
  passwordHash               String                   @map("password_hash") @db.VarChar(255)
  nickname                   String                   @db.VarChar(64)
  role                       UserRole
  status                     UserStatus
  timezone                   String                   @default("UTC") @db.VarChar(64)
  avatarUrl                  String?                  @map("avatar_url") @db.VarChar(512)
  lastLoginAt                DateTime?                @map("last_login_at") @db.Timestamptz(6)
  passwordChangedAt          DateTime?                @map("password_changed_at") @db.Timestamptz(6)
  forcePasswordChange        Boolean                  @default(false) @map("force_password_change")
  createdAt                  DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                  DateTime?                @map("deleted_at") @db.Timestamptz(6)
  authRefreshTokens          AuthRefreshToken[]
  receivedPasswordResetTokens AuthPasswordResetToken[] @relation("PasswordResetTargetUser")
  issuedPasswordResetTokens  AuthPasswordResetToken[] @relation("PasswordResetCreatedByUser")
  devices                    Device[]
  todoLists                  TodoList[]
  tags                       Tag[]
  todos                      Todo[]
  reminders                  Reminder[]
  reminderEvents             ReminderEvent[]
  notificationEndpoints      NotificationEndpoint[]
  adminOperationLogsAsAdmin  AdminOperationLog[]      @relation("AdminOperationActor")
  adminOperationLogsAsTarget AdminOperationLog[]      @relation("AdminOperationTarget")

  @@index([role, status, createdAt(sort: Desc)])
  @@index([status, lastLoginAt(sort: Desc)])
  @@map("users")
}

model AuthRefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  deviceId     String?   @map("device_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokeReason String?   @map("revoke_reason") @db.VarChar(64)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  device       Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt, expiresAt])
  @@index([deviceId, revokedAt])
  @@map("auth_refresh_tokens")
}

model AuthPasswordResetToken {
  id                    String            @id @default(uuid()) @db.Uuid
  userId                String            @map("user_id") @db.Uuid
  createdByUserId       String?           @map("created_by_user_id") @db.Uuid
  tokenHash             String            @unique @map("token_hash") @db.VarChar(255)
  mode                  PasswordResetMode
  temporaryPasswordHash String?           @map("temporary_password_hash") @db.VarChar(255)
  reason                String            @db.VarChar(255)
  expiresAt             DateTime          @map("expires_at") @db.Timestamptz(6)
  consumedAt            DateTime?         @map("consumed_at") @db.Timestamptz(6)
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User              @relation("PasswordResetTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  createdByUser         User?             @relation("PasswordResetCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([userId, expiresAt(sort: Desc)])
  @@index([createdByUserId, createdAt(sort: Desc)])
  @@map("auth_password_reset_tokens")
}

model Device {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  platform          PlatformType
  deviceName        String             @map("device_name") @db.VarChar(128)
  deviceIdentifier  String?            @map("device_identifier") @db.VarChar(255)
  appVersion        String?            @map("app_version") @db.VarChar(32)
  pushToken         String?            @map("push_token") @db.VarChar(512)
  lastActiveAt      DateTime?          @map("last_active_at") @db.Timestamptz(6)
  lastIp            String?            @map("last_ip") @db.VarChar(64)
  isOnline          Boolean            @default(false) @map("is_online")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?          @map("deleted_at") @db.Timestamptz(6)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  authRefreshTokens AuthRefreshToken[]

  @@index([userId, platform, lastActiveAt(sort: Desc)])
  @@index([deviceIdentifier])
  @@map("devices")
}

model TodoList {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar(64)
  color     String?   @db.VarChar(16)
  isDefault Boolean   @default(false) @map("is_default")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos     Todo[]

  @@index([userId, isDefault])
  @@index([userId, sortOrder])
  @@map("todo_lists")
}

model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar(32)
  color     String?   @db.VarChar(16)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoTags  TodoTag[]

  @@unique([userId, name])
  @@map("tags")
}

model Todo {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  listId         String?       @map("list_id") @db.Uuid
  title          String        @db.VarChar(200)
  description    String?
  status         TodoStatus
  priority       TodoPriority  @default(medium)
  dueAt          DateTime?     @map("due_at") @db.Timestamptz(6)
  isAllDay       Boolean       @default(false) @map("is_all_day")
  sourcePlatform PlatformType? @map("source_platform")
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz(6)
  archivedAt     DateTime?     @map("archived_at") @db.Timestamptz(6)
  version        BigInt        @default(1)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  list           TodoList?     @relation(fields: [listId], references: [id], onDelete: SetNull)
  tags           TodoTag[]
  reminders      Reminder[]
  reminderEvents ReminderEvent[]

  @@index([userId, status, updatedAt(sort: Desc)])
  @@index([userId, dueAt(sort: Asc)])
  @@index([userId, listId, status, updatedAt(sort: Desc)])
  @@map("todos")
}

model TodoTag {
  todoId    String   @map("todo_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([todoId, tagId])
  @@index([tagId, todoId])
  @@map("todo_tags")
}

model Reminder {
  id              String             @id @default(uuid()) @db.Uuid
  todoId          String             @map("todo_id") @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  channel         ReminderChannel
  repeatType      ReminderRepeatType @default(none) @map("repeat_type")
  repeatRule      Json?              @map("repeat_rule")
  remindAt        DateTime           @map("remind_at") @db.Timestamptz(6)
  timezone        String?            @db.VarChar(64)
  status          ReminderStatus     @default(pending)
  lastTriggeredAt DateTime?          @map("last_triggered_at") @db.Timestamptz(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz(6)
  todo            Todo               @relation(fields: [todoId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderEvents  ReminderEvent[]

  @@index([remindAt, status])
  @@index([userId, status, remindAt])
  @@index([todoId, status])
  @@map("reminders")
}

model ReminderEvent {
  id             String              @id @default(uuid()) @db.Uuid
  reminderId     String              @map("reminder_id") @db.Uuid
  todoId         String              @map("todo_id") @db.Uuid
  userId         String              @map("user_id") @db.Uuid
  channel        ReminderChannel
  scheduledFor   DateTime            @map("scheduled_for") @db.Timestamptz(6)
  triggeredAt    DateTime            @map("triggered_at") @db.Timestamptz(6)
  dedupeKey      String              @unique @map("dedupe_key") @db.VarChar(255)
  status         ReminderEventStatus @default(pending)
  payload        Json?
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  reminder       Reminder            @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  todo           Todo                @relation(fields: [todoId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries     NotificationDelivery[]

  @@index([userId, triggeredAt(sort: Desc)])
  @@index([status, triggeredAt(sort: Desc)])
  @@map("reminder_events")
}

model NotificationEndpoint {
  id              String                   @id @default(uuid()) @db.Uuid
  userId          String                   @map("user_id") @db.Uuid
  type            NotificationEndpointType @default(webhook)
  name            String                   @db.VarChar(64)
  targetUrl       String                   @map("target_url") @db.VarChar(1024)
  secret          String?                  @db.VarChar(255)
  payloadTemplate String?                  @map("payload_template") @db.Text
  isEnabled       Boolean                  @default(true) @map("is_enabled")
  lastSuccessAt   DateTime?                @map("last_success_at") @db.Timestamptz(6)
  lastFailureAt   DateTime?                @map("last_failure_at") @db.Timestamptz(6)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?                @map("deleted_at") @db.Timestamptz(6)
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries      NotificationDelivery[]

  @@index([userId, type, isEnabled])
  @@map("notification_endpoints")
}

model NotificationDelivery {
  id              String                     @id @default(uuid()) @db.Uuid
  reminderEventId String                     @map("reminder_event_id") @db.Uuid
  endpointId      String                     @map("endpoint_id") @db.Uuid
  status          NotificationDeliveryStatus @default(pending)
  attemptCount    Int                        @default(0) @map("attempt_count")
  nextRetryAt     DateTime?                  @map("next_retry_at") @db.Timestamptz(6)
  responseCode    Int?                       @map("response_code")
  responseBody    String?                    @map("response_body")
  lastError       String?                    @map("last_error")
  deliveredAt     DateTime?                  @map("delivered_at") @db.Timestamptz(6)
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  reminderEvent   ReminderEvent              @relation(fields: [reminderEventId], references: [id], onDelete: Cascade)
  endpoint        NotificationEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([endpointId, createdAt(sort: Desc)])
  @@index([reminderEventId])
  @@map("notification_deliveries")
}

model AdminOperationLog {
  id           String               @id @default(uuid()) @db.Uuid
  adminUserId  String               @map("admin_user_id") @db.Uuid
  targetUserId String?              @map("target_user_id") @db.Uuid
  action       AdminOperationAction
  reason       String               @db.VarChar(255)
  metadata     Json?
  result       AdminOperationResult
  ipAddress    String?              @map("ip_address") @db.VarChar(64)
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  adminUser    User                 @relation("AdminOperationActor", fields: [adminUserId], references: [id], onDelete: Cascade)
  targetUser   User?                @relation("AdminOperationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId, createdAt(sort: Desc)])
  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("admin_operation_logs")
}
