# 默认生产环境模板
# 复制为 .env 后，请按实际部署环境替换域名、数据库连接串和密钥

# 当前运行环境，例如 development / production
NODE_ENV=production
# 后端 HTTP 服务监听端口
PORT=3000
# 服务名称，用于日志或页面展示
APP_NAME=CloudTodo Server
# 当前服务的对外访问基础地址
APP_BASE_URL=https://todo.example.com
# PostgreSQL 连接串
DATABASE_URL=postgresql://cloudtodo:change-me-db-password@db.example.com:5432/cloudtodo?schema=public
# 用户会话签名密钥
JWT_ACCESS_SECRET=change-me-access-secret
# 预留给 refresh token 体系的签名密钥
JWT_REFRESH_SECRET=change-me-refresh-secret
# Webhook 默认签名密钥
WEBHOOK_SIGNING_SECRET=change-me-webhook-secret
# 管理员后台会话签名密钥
ADMIN_SESSION_SECRET=change-me-admin-session-secret
# 初始化管理员的用户名
ADMIN_SEED_USERNAME=admin
# 初始化管理员的邮箱
ADMIN_SEED_EMAIL=admin@todo.example.com
# 初始化管理员的密码
ADMIN_SEED_PASSWORD=change-me-admin-password
# 初始化管理员的显示昵称
ADMIN_SEED_NICKNAME=System Admin
# 初始化管理员的默认时区
ADMIN_SEED_TIMEZONE=Asia/Shanghai
# 是否额外创建演示普通用户，true 创建，false 不创建
DEMO_USER_ENABLED=false
# 演示普通用户邮箱
DEMO_USER_EMAIL=demo@example.com
# 演示普通用户用户名
DEMO_USER_USERNAME=demo
# 演示普通用户密码
DEMO_USER_PASSWORD=demo123456
# 演示普通用户显示昵称
DEMO_USER_NICKNAME=Demo User
# 演示普通用户默认时区
DEMO_USER_TIMEZONE=Asia/Shanghai
# 是否启用提醒调度器和投递 worker
SCHEDULER_ENABLED=true
# 扫描到期提醒的时间间隔，单位毫秒
SCHEDULER_SCAN_INTERVAL_MS=5000
# 扫描待投递 webhook 任务的时间间隔，单位毫秒
DELIVERY_SCAN_INTERVAL_MS=5000
# 单条 webhook 投递的最大尝试次数
DELIVERY_MAX_ATTEMPTS=3
